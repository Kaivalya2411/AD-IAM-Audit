# AD/IAM Auditor — Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit .env to version control

FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string-in-production
DATABASE_PATH=instance/adaudit.db

# Login security
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# Optional: real Active Directory
AD_SERVER=
AD_USER=
AD_PASSWORD=
AD_BASE_DN=
STALE_DAYS=90
